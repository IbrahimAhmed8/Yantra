# Python AI microservice used by the Next.js Yantra chat route.
YANTRA_AI_SERVICE_URL="https://YOUR-YANTRA-AI-SERVICE.onrender.com"
YANTRA_AI_SERVICE_TIMEOUT_MS="65000"

# Gemini API key used by the docs support route and as a fallback when the AI service URL is not set.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase project settings for auth + persisted student profiles.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# LiveKit room-side Yantra assistant.
LIVEKIT_URL="wss://YOUR_PROJECT.livekit.cloud"
LIVEKIT_API_KEY="YOUR_LIVEKIT_API_KEY"
LIVEKIT_API_SECRET="YOUR_LIVEKIT_API_SECRET"
YANTRA_LIVEKIT_AGENT_NAME="yantra-terminal-voice"

# Day 2 editor execution UI.
VITE_USE_MOCK_API="true"
